<Application x:Class="FredRdpManager.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FredRdpManager"
             StartupUri="MainWindow.xaml">
  <Application.Resources>
    <!-- Palette bleue partagée -->
    <SolidColorBrush x:Key="BrushTextPrimary" Color="#1A365D"/>
    <SolidColorBrush x:Key="BrushTextSecondary" Color="#2C5282"/>

    <LinearGradientBrush x:Key="BrushMainWindowBg" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#C5D8EC" Offset="0"/>
      <GradientStop Color="#E4EEF8" Offset="0.55"/>
      <GradientStop Color="#D8E6F4" Offset="1"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="BrushSidebarBg" Color="#B8CFE6"/>
    <SolidColorBrush x:Key="BrushDetailBg" Color="#E8F1FA"/>
    <SolidColorBrush x:Key="BrushSplitter" Color="#8FA8C4"/>

    <LinearGradientBrush x:Key="BrushDialogWindowBg" StartPoint="0,0" EndPoint="0,1">
      <GradientStop Color="#D0E2F4" Offset="0"/>
      <GradientStop Color="#E8F2FC" Offset="1"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="BrushListBg" Color="#F5FAFD"/>
    <SolidColorBrush x:Key="BrushListBorder" Color="#9BB5D1"/>
    <SolidColorBrush x:Key="BrushFieldBg" Color="#FCFEFF"/>

    <Style TargetType="ListBox">
      <Setter Property="Background" Value="{StaticResource BrushListBg}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BrushListBorder}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
    </Style>

    <Style TargetType="Button">
      <Setter Property="Background" Value="#E8F2FC"/>
      <Setter Property="BorderBrush" Value="#6B8EB8"/>
      <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
      <Setter Property="Padding" Value="10,5"/>
    </Style>
  </Application.Resources>
</Application>
