<Window x:Class="FredRdpManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        xmlns:local="clr-namespace:FredRdpManager"
        mc:Ignorable="d"
        Title="Fred RDP Manager"
        Height="480"
        Width="720"
        MinHeight="360"
        MinWidth="520"
        Background="{StaticResource BrushMainWindowBg}"
        Closing="MainWindow_OnClosing">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="240" MinWidth="180"/>
      <ColumnDefinition Width="Auto"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0"
            Background="{StaticResource BrushSidebarBg}"
            Padding="8"
            BorderBrush="#7A9ABE"
            BorderThickness="0,0,1,0">
      <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Vertical" Margin="0,0,0,8">
          <Button x:Name="AddButton"     Content="Ajouter…"    Margin="0,0,0,4" Click="AddButton_OnClick"/>
          <Button x:Name="EditButton"    Content="Modifier…"   Margin="0,0,0,4" Click="EditButton_OnClick"/>
          <Button x:Name="RemoveButton"  Content="Supprimer"   Margin="0,0,0,4" Click="RemoveButton_OnClick"/>
          <Button x:Name="ConnectButton" Content="Se connecter"                  Click="ConnectButton_OnClick"/>
        </StackPanel>

        <!-- Liste avec pastille colorée selon l'état de connexion -->
        <ListBox x:Name="ConnectionsList"
                 MouseDoubleClick="ConnectionsList_OnMouseDoubleClick">
          <ListBox.ItemTemplate>
            <DataTemplate DataType="{x:Type local:ConnectionViewModel}">
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Pastille : verte si connecté, grise sinon -->
                <Ellipse Width="10" Height="10"
                         VerticalAlignment="Center"
                         Margin="0,0,6,0">
                  <Ellipse.Style>
                    <Style TargetType="Ellipse">
                      <Setter Property="Fill" Value="#8FA8C4"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                          <Setter Property="Fill" Value="#22C55E"/>
                          <Setter Property="Effect">
                            <Setter.Value>
                              <DropShadowEffect Color="#22C55E" BlurRadius="6" ShadowDepth="0"/>
                            </Setter.Value>
                          </Setter>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

    <GridSplitter Grid.Column="1"
                  Width="4"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Stretch"
                  Background="{StaticResource BrushSplitter}"/>

    <Border Grid.Column="2"
            Background="{StaticResource BrushDetailBg}"
            Padding="16"
            BorderBrush="#B8CFE0"
            BorderThickness="1,0,0,0">
      <DockPanel LastChildFill="True">
        <TextBlock DockPanel.Dock="Top"
                   TextWrapping="Wrap"
                   FontSize="14"
                   Margin="0,0,0,12"
                   Foreground="{StaticResource BrushTextPrimary}"
                   Text="Sélectionnez une connexion à gauche, puis double-cliquez ou cliquez « Se connecter » pour ouvrir une session RDP."/>
        <TextBlock x:Name="DetailText"
                   DockPanel.Dock="Top"
                   TextWrapping="Wrap"
                   Foreground="{StaticResource BrushTextSecondary}"
                   Margin="0,0,0,12"/>

        <Border Background="#F2F8FE"
                BorderBrush="#9BB5D1"
                BorderThickness="1"
                CornerRadius="4"
                Padding="8">
          <wfi:WindowsFormsHost x:Name="RdpHost" />
        </Border>
      </DockPanel>
    </Border>
  </Grid>
</Window>
