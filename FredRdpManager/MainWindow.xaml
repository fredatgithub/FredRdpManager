<Window x:Class="FredRdpManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Fred RDP Manager"
        Height="480"
        Width="720"
        MinHeight="360"
        MinWidth="520"
        Closing="MainWindow_OnClosing">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="240" MinWidth="180"/>
      <ColumnDefinition Width="Auto"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <DockPanel Grid.Column="0" Margin="8">
      <StackPanel DockPanel.Dock="Top" Orientation="Vertical" Margin="0,0,0,8">
        <Button x:Name="AddButton" Content="Ajouter…" Margin="0,0,0,4" Click="AddButton_OnClick"/>
        <Button x:Name="EditButton" Content="Modifier…" Margin="0,0,0,4" Click="EditButton_OnClick"/>
        <Button x:Name="RemoveButton" Content="Supprimer" Margin="0,0,0,4" Click="RemoveButton_OnClick"/>
        <Button x:Name="ConnectButton" Content="Se connecter" Click="ConnectButton_OnClick"/>
      </StackPanel>
      <ListBox x:Name="ConnectionsList"
               DisplayMemberPath="DisplayName"
               MouseDoubleClick="ConnectionsList_OnMouseDoubleClick"/>
    </DockPanel>

    <GridSplitter Grid.Column="1"
                  Width="4"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Stretch"
                  Background="#DDD"/>

    <DockPanel Grid.Column="2" Margin="16">
      <TextBlock DockPanel.Dock="Top"
                 TextWrapping="Wrap"
                 FontSize="14"
                 Margin="0,0,0,12"
                 Text="Sélectionnez une connexion à gauche, puis « Se connecter », ou double-cliquez sur une entrée. Les connexions sont enregistrées dans votre profil utilisateur à la fermeture de l’application."/>
      <TextBlock x:Name="DetailText"
                 DockPanel.Dock="Top"
                 TextWrapping="Wrap"
                 Foreground="#444"/>
    </DockPanel>
  </Grid>
</Window>
