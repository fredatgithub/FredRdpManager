<Window x:Class="FredRdpManager.AddConnectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connexion RDP"
        Height="318"
        Width="440"
        MinHeight="300"
        MinWidth="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource BrushDialogWindowBg}">
  <Border Margin="12"
          Padding="16"
          Background="#E2EEF8"
          BorderBrush="#8FAFCE"
          BorderThickness="1"
          CornerRadius="4">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="120"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8"
                 Foreground="{StaticResource BrushTextPrimary}" Text="Serveur :"/>
      <TextBox x:Name="ServerTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8"
               Background="{StaticResource BrushFieldBg}" BorderBrush="#9BB5D1"/>

      <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8"
                 Foreground="{StaticResource BrushTextPrimary}" Text="Port RDP :"/>
      <TextBox x:Name="PortTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8"
               Background="{StaticResource BrushFieldBg}" BorderBrush="#9BB5D1"/>

      <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8"
                 Foreground="{StaticResource BrushTextPrimary}" Text="Domaine :"/>
      <TextBox x:Name="DomainTextBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8"
               Background="{StaticResource BrushFieldBg}" BorderBrush="#9BB5D1"/>

      <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,8"
                 Foreground="{StaticResource BrushTextPrimary}" Text="Utilisateur :"/>
      <TextBox x:Name="UserTextBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,8"
               Background="{StaticResource BrushFieldBg}" BorderBrush="#9BB5D1"/>

      <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"
                 Foreground="{StaticResource BrushTextPrimary}" Text="Mot de passe :"/>
      <PasswordBox x:Name="PasswordBox" Grid.Row="4" Grid.Column="1"
                   Background="{StaticResource BrushFieldBg}" BorderBrush="#9BB5D1"/>

      <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                  Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
        <Button x:Name="OkButton" Content="OK" Width="88" Margin="0,0,8,0" IsDefault="True" Click="OkButton_Click"/>
        <Button Content="Annuler" Width="88" IsCancel="True"/>
      </StackPanel>
    </Grid>
  </Border>
</Window>
